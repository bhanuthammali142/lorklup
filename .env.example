# HostelOS — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# ── Supabase (required) ────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Service Role Key (REMOVED from frontend) ───────────────────────────────────
# The service role key must NOT be in frontend env vars.
# It is set as a Supabase Edge Function secret only:
#
#   supabase secrets set SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
#
# DO NOT add VITE_SUPABASE_SERVICE_ROLE_KEY here. Any VITE_ variable is
# embedded in the browser bundle and visible to all users.
